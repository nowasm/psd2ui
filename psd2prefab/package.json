{
  "name": "psd2prefab",
  "version": "1.2.0",
  "description": "Convert Photoshop .psd files to Cocos Creator 3.4+ (or 2.4.x) prefab + .png + .meta. Standalone Node CLI.",
  "main": "dist/index.js",
  "engines": {
    "node": ">=18.12.0 || >=20.9.0"
  },
  "scripts": {
    "start": "node dist/index.js",
    "build": "tsc -b",
    "watch": "tsc -w",
    "help": "node dist/index.js --h",
    "test-png9": "node dist/index.js --engine-version v342 --pinyin --input ./test/png9.psd --output ./out/",
    "test-same-name": "node dist/index.js --engine-version v342 --pinyin --input ./test/sameName.psd --output ./out/ --cache ./cache/cache.json"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "ag-psd": "^15.0.0",
    "canvas": "^3.2.1",
    "fs-extra": "^10.1.0",
    "minimist": "^1.2.7",
    "pinyin-pro": "^3.16.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^9.0.13",
    "@types/node": "^18.11.9",
    "ts-node": "^10.9.1",
    "tslib": "^2.6.0",
    "typescript": "^5.6.3"
  }
}
